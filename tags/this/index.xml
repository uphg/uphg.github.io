let x = &#39;x&#39;let a = &#39;1&#39;function f1(x) {return x + a}a = &#39;3&#39;{let a = &#39;2&#39;f1(&#39;x&#39;) // &#39;x3&#39;}a = &#39;4&#39;例2</description>
